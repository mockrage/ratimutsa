generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum AdminRole {
  REGULAR_ADMIN
  SENIOR_ADMIN
}

enum WorkflowState {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

enum CustomerType {
  B2C
  B2B
}

enum DeliveryOption {
  DELIVERY
  PICKUP
}

enum DeliverySlot {
  MORNING
  MIDDAY
  END_OF_DAY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DELIVERED
  CANCELLED
}

enum PreOrderStatus {
  QUEUED
  FULFILLED
  CANCELLED
}

enum ReservationType {
  B2B_CART
  ORDER_PAID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  SUBMIT
}

enum NotificationType {
  APPROVAL_REQUIRED
  LOW_STOCK
  CONCURRENT_EDIT
  PREORDER_FULFILLED
}

enum AnnouncementType {
  BANNER
  POPUP
  BOTH
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(STAFF)
  adminRole AdminRole @default(REGULAR_ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  auditLogs     AuditLog[]
  notifications AdminNotification[]

  @@map("users")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model Product {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  description       String
  price             Float
  quantity          Int
  unit              String
  imageUrl          String
  images            Json             @default("[]")
  categoryId        String
  category          Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isSeasonal        Boolean          @default(false)
  isAvailable       Boolean          @default(true)
  lowStockThreshold Int              @default(10)
  workflowState     WorkflowState    @default(DRAFT)
  rejectionNotes    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  orderItems        OrderItem[]
  variants          ProductVariant[]

  @@index([categoryId])
  @@index([slug])
  @@index([workflowState])
  @@map("products")
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name           String
  sku            String   @unique
  b2cPrice       Float
  b2bPrice       Float
  inventory      Int
  minOrderQtyB2C Int      @default(1)
  minOrderQtyB2B Int      @default(1)
  unit           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems   OrderItem[]
  preOrders    PreOrder[]
  reservations InventoryReservation[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model Announcement {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      AnnouncementType @default(BANNER)
  isActive  Boolean          @default(true)
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("announcements")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  content   String
  rating    Int      @default(5)
  location  String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model HarvestCalendar {
  id          String   @id @default(cuid())
  productName String
  startMonth  Int
  endMonth    Int
  year        Int?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("harvest_calendar")
}

model OrderRequest {
  id              String         @id @default(cuid())
  customerName    String
  customerPhone   String
  customerEmail   String?
  customerType    CustomerType
  deliveryOption  DeliveryOption
  deliverySlot    DeliverySlot?
  deliveryDate    DateTime?
  deliveryAddress String?
  notes           String?
  status          OrderStatus    @default(PENDING)
  totalAmount     Float
  deliveryFee     Float          @default(0)
  adminNotes      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([customerType])
  @@map("order_requests")
}

model OrderItem {
  id             String          @id @default(cuid())
  orderRequestId String
  orderRequest   OrderRequest    @relation(fields: [orderRequestId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?        @relation(fields: [productId], references: [id])
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  quantity       Int
  price          Float
  createdAt      DateTime        @default(now())

  @@index([orderRequestId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model PreOrder {
  id            String         @id @default(cuid())
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  customerEmail String
  customerName  String
  quantity      Int
  status        PreOrderStatus @default(QUEUED)
  queuePosition Int
  createdAt     DateTime       @default(now())
  fulfilledAt   DateTime?

  @@index([variantId, status])
  @@index([createdAt])
  @@map("pre_orders")
}

model InventoryReservation {
  id            String          @id @default(cuid())
  variantId     String
  variant       ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity      Int
  customerEmail String
  type          ReservationType
  expiresAt     DateTime
  createdAt     DateTime        @default(now())

  @@index([variantId])
  @@index([expiresAt])
  @@map("inventory_reservations")
}

model AuditLog {
  id         String      @id @default(cuid())
  adminId    String
  admin      User        @relation(fields: [adminId], references: [id])
  entityType String
  entityId   String
  action     AuditAction
  changes    Json
  timestamp  DateTime    @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

model AdminNotification {
  id        String           @id @default(cuid())
  adminId   String?
  admin     User?            @relation(fields: [adminId], references: [id])
  type      NotificationType
  message   String
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([adminId, isRead])
  @@index([createdAt])
  @@map("admin_notifications")
}
